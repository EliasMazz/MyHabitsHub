                android:endX="700" android:endY="800">
                <item android:offset="0.0" android:color="#FF4285F4"/>
                <item android:offset="0.45" android:color="#FF41DDD0"/>
                <item android:offset="0.8" android:color="#FF93F4EA"/>
                <item android:offset="1.0" android:color="#FFFDDEA4"/>
